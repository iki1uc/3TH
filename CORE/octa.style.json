{
  "octa-style": {
    "version": "1.0",
    "deck": 3,
    "visual-core": true,

    "axes": {
      "X":   { "color": "#ff3b3b", "glow": true, "width": 2 },
      "Y":   { "color": "#3bff3b", "glow": true, "width": 2 },
      "Z":   { "color": "#3b3bff", "glow": true, "width": 2 },
      "T":   { "color": "#ffaa00", "pulse": true, "width": 2 },
      "S":   { "color": "#ffffff", "alpha": 0.6, "width": 1 },

      "MOVE":  { "color": "#00eaff", "dash": true },
      "STATE": { "color": "#ff00ea", "dash": true },
      "FLOW":  { "color": "#00ffea", "wave": true }
    },

    "raw": {
      "X.raw":     { "opacity": 0.8, "blur": 2 },
      "Y.raw":     { "opacity": 0.8, "blur": 2 },
      "Z.raw":     { "opacity": 0.8, "blur": 2 },
      "T.raw":     { "opacity": 0.9, "pulse": true },
      "S.raw":     { "opacity": 0.5, "blur": 1 },
      "move.raw":  { "opacity": 0.7, "dash": true },
      "state.raw": { "opacity": 0.7, "dash": true },
      "flow.raw":  { "opacity": 1.0, "wave": true }
    },

    "fusion": {
      "octa-core": {
        "glow": true,
        "color": "#00c8ff",
        "strength": 1.0
      },
      "octa-sync": {
        "pulse": true,
        "color": "#ff00c8",
        "speed": 1.2
      },
      "octa-visual": {
        "grid": true,
        "grid-color": "#222222",
        "grid-alpha": 0.4
      },
      "octa-deck": {
        "highlight": true,
        "color": "#00ff88"
      }
    },

    "panel": {
      "background": "#0a0a0a",
      "border": "#1f1f1f",
      "radius": 6,
      "shadow": true
    },

    "style-flags": {
      "use-glow": true,
      "use-pulse": true,
      "use-wave": true,
      "use-dash": true,
      "use-grid": true
    }
  }
}

