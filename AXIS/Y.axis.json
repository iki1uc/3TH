{
  "axis-y": {
    "version": "1.0",
    "axis-id": 2,
    "axis-name": "Y",
    "axis-type": "primary",
    "deck": 3,

    "vector": {
      "x": 0.0,
      "y": 1.0,
      "z": 0.0
    },

    "style": {
      "color": "#3bff3b",
      "width": 2,
      "render": "line",
      "glow": true
    },

    "raw": {
      "id": "Y.raw",
      "opacity": 0.8,
      "blur": 2,
      "pulse": false,
      "dash": false,
      "wave": false
    },

    "sync": {
      "latency": 0.1,
      "mode": "hard",
      "speed": 1.0
    },

    "fusion": {
      "pair": "Y+Z",
      "strength": 1.0,
      "mode": "vector",
      "color": "#33ff99"
    },

    "routing": {
      "axis-route": "OCTA-AXIS-Y",
      "raw-route": "OCTA-RAW-Y",
      "sync-route": "OCTA-SYNC-Y",
      "visual-route": "OCTA-VISUAL-Y",
      "fuse-route": "OCTA-FUSE-Y",
      "deck-route": "OCTA-DECK-Y"
    },

    "flags": {
      "enable-axis": true,
      "enable-raw": true,
      "enable-sync": true,
      "enable-fusion": true,
      "enable-visual": true,
      "enable-deck": true
    },

    "output": {
      "axis-y-core": "AXIS-Y-CORE",
      "axis-y-raw": "AXIS-Y-RAW",
      "axis-y-system": "AXIS-Y-SYSTEM"
    }
  }
}

