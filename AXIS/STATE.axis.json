{
  "axis-state": {
    "version": "1.0",
    "axis-id": 7,
    "axis-name": "STATE",
    "axis-type": "state",
    "deck": 3,

    "vector": {
      "x": 1.0,
      "y": 0.5,
      "z": 1.0
    },

    "style": {
      "color": "#ff00ea",
      "width": 2,
      "render": "dash",
      "glow": true
    },

    "raw": {
      "id": "state.raw",
      "opacity": 0.7,
      "dash": true,
      "blur": 1,
      "pulse": false,
      "wave": false
    },

    "sync": {
      "latency": 0.15,
      "mode": "dash",
      "speed": 1.1
    },

    "fusion": {
      "pair": "MOVE+STATE",
      "strength": 0.9,
      "mode": "dash",
      "color": "#ff00ea"
    },

    "routing": {
      "axis-route": "OCTA-AXIS-STATE",
      "raw-route": "OCTA-RAW-STATE",
      "sync-route": "OCTA-SYNC-STATE",
      "visual-route": "OCTA-VISUAL-STATE",
      "fuse-route": "OCTA-FUSE-STATE",
      "deck-route": "OCTA-DECK-STATE"
    },

    "flags": {
      "enable-axis": true,
      "enable-raw": true,
      "enable-sync": true,
      "enable-fusion": true,
      "enable-visual": true,
      "enable-deck": true
    },

    "output": {
      "axis-state-core": "AXIS-STATE-CORE",
      "axis-state-raw": "AXIS-STATE-RAW",
      "axis-state-system": "AXIS-STATE-SYSTEM"
    }
  }
}

