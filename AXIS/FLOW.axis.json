{
  "axis-flow": {
    "version": "1.0",
    "axis-id": 8,
    "axis-name": "FLOW",
    "axis-type": "flow",
    "deck": 3,

    "vector": {
      "x": 0.5,
      "y": 0.5,
      "z": 1.0
    },

    "style": {
      "color": "#00ffee",
      "width": 3,
      "render": "wave",
      "glow": true
    },

    "raw": {
      "id": "flow.raw",
      "opacity": 1.0,
      "wave": true,
      "blur": 0,
      "pulse": false,
      "dash": false
    },

    "sync": {
      "latency": 0.05,
      "mode": "wave",
      "speed": 1.4
    },

    "fusion": {
      "pair": "FLOW+T",
      "strength": 1.2,
      "mode": "wave",
      "color": "#00ffee"
    },

    "routing": {
      "axis-route": "OCTA-AXIS-FLOW",
      "raw-route": "OCTA-RAW-FLOW",
      "sync-route": "OCTA-SYNC-FLOW",
      "visual-route": "OCTA-VISUAL-FLOW",
      "fuse-route": "OCTA-FUSE-FLOW",
      "deck-route": "OCTA-DECK-FLOW"
    },

    "flags": {
      "enable-axis": true,
      "enable-raw": true,
      "enable-sync": true,
      "enable-fusion": true,
      "enable-visual": true,
      "enable-deck": true
    },

    "output": {
      "axis-flow-core": "AXIS-FLOW-CORE",
      "axis-flow-raw": "AXIS-FLOW-RAW",
      "axis-flow-system": "AXIS-FLOW-SYSTEM"
    }
  }
}

