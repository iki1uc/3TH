{
  "quad-sync": {
    "version": "1.0",
    "layer": "QUAD",
    "deck": 3,

    "sync-core": {
      "mode": "multi",
      "latency": 0.1,
      "stability": 1.0
    },

    "sync-map": {
      "X":     { "mode": "hard",  "speed": 1.0 },
      "Y":     { "mode": "hard",  "speed": 1.0 },
      "Z":     { "mode": "hard",  "speed": 1.0 },
      "T":     { "mode": "pulse", "speed": 1.2 },
      "S":     { "mode": "soft",  "speed": 0.8 },
      "MOVE":  { "mode": "dash",  "speed": 1.1 },
      "STATE": { "mode": "dash",  "speed": 1.1 },
      "FLOW":  { "mode": "wave",  "speed": 1.3 }
    },

    "sync-fusion": {
      "vector": {
        "X+Y": { "sync": "hard" },
        "Y+Z": { "sync": "hard" },
        "Z+X": { "sync": "hard" }
      },
      "pulse": {
        "T+S": { "sync": "pulse" }
      },
      "dash": {
        "MOVE+STATE": { "sync": "dash" }
      },
      "wave": {
        "FLOW+T": { "sync": "wave" }
      }
    },

    "sync-routing": {
      "axis-route": "QUAD-SYNC-AXIS",
      "fusion-route": "QUAD-SYNC-FUSION",
      "visual-route": "QUAD-SYNC-VISUAL"
    },

    "sync-output": {
      "quad-sync-system": "QUAD-SYNC-SYSTEM",
      "quad-sync-visual": "QUAD-SYNC-VISUAL"
    }
  }
}
